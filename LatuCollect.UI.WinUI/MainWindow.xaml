<Window
    x:Class="LatuCollect.UI.WinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>

        <!--  STRUCTURE PRINCIPALE  -->

        <!--  LIGNES  -->
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  COLONNES  -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*" />
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="5*" />
        </Grid.ColumnDefinitions>

        <!--  ZONE GAUCHE  -->
        <Border
            Grid.Row="0"
            Grid.Column="0"
            Margin="5"
            Background="#1E1E1E">

            <StackPanel>

                <TextBlock
                    Margin="5"
                    Foreground="White"
                    Text="📁 Projet" />

                <TextBlock
                    Margin="5"
                    Foreground="White"
                    Text="   📁 Core" />
                <CheckBox
                    Margin="20,5"
                    Content="FileImportService.cs"
                    Foreground="White" />
                <CheckBox
                    Margin="20,5"
                    Content="FileExportService.cs"
                    Foreground="White" />

                <TextBlock
                    Margin="5"
                    Foreground="White"
                    Text="   📁 UI" />
                <CheckBox
                    Margin="20,5"
                    Content="MainWindow.xaml"
                    Foreground="White" />

                <CheckBox
                    Margin="5"
                    Content="README.md"
                    Foreground="White" />

            </StackPanel>

        </Border>

        <!--  ZONE CENTRE  -->
        <Border
            Grid.Row="0"
            Grid.Column="1"
            Margin="5"
            Background="#2D2D30">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">

                <TextBlock
                    Margin="0,0,0,10"
                    HorizontalAlignment="Center"
                    Foreground="White"
                    Text="FORMAT" />

                <RadioButton
                    Margin="0,5"
                    Content="TXT"
                    IsChecked="True" />
                <RadioButton Margin="0,5" Content="Markdown" />

            </StackPanel>
        </Border>

        <!--  ZONE DROITE  -->
        <Border
            Grid.Row="0"
            Grid.Column="2"
            Margin="5"
            Background="#252526">
            <ScrollViewer>
                <TextBlock
                    Margin="10"
                    Foreground="White"
                    Text="Aperçu du contenu ici..."
                    TextWrapping="Wrap" />
            </ScrollViewer>
        </Border>

        <!--  ZONE BASSE  -->
        <Border
            Grid.Row="1"
            Grid.ColumnSpan="3"
            Padding="10"
            Background="#333333">
            <Button
                Width="140"
                Height="40"
                HorizontalAlignment="Right"
                Content="Exporter" />
        </Border>

    </Grid>

</Window>    
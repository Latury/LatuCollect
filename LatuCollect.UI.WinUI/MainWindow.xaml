<!--
    ╔══════════════════════════════════════════════════════════════════════╗
    ║                        LATUCOLLECT                                   ║
    ║  Module : UI                                                         ║
    ║  Fichier : MainWindow.xaml                                           ║
    ║                                                                      ║
    ║  Rôle : Interface utilisateur principale                             ║
    ║                                                                      ║
    ║  Respect ALC :                                                       ║
    ║  - Aucune logique métier                                             ║
    ║  - Binding uniquement                                                ║
    ║  - Structure claire et maintenable                                   ║
    ╚══════════════════════════════════════════════════════════════════════╝
-->

<Window
    x:Class="LatuCollect.UI.WinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="using:LatuCollect.UI.WinUI.Converters"
    xmlns:models="using:LatuCollect.UI.WinUI.Models">

    <Grid>

        <!--  =========================  -->
        <!--  RESSOURCES UI  -->
        <!--  =========================  -->

        <Grid.Resources>
            <conv:BoolToIconConverter x:Key="BoolToIconConverter" />
            <conv:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
            <conv:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter" />
            <conv:LogLevelToColorConverter x:Key="LogLevelToColorConverter" />

            <!--  🧾 TEMPLATE LOGS  -->
            <DataTemplate x:Key="LogItemTemplate">
                <Border
                    Margin="2"
                    Padding="6"
                    Background="#2D2D30"
                    BorderBrush="{Binding Level, Converter={StaticResource LogLevelToColorConverter}}"
                    BorderThickness="0,0,0,1"
                    CornerRadius="4">

                    <StackPanel Spacing="4">

                        <!--  Ligne 1 : Date + Niveau  -->
                        <StackPanel Orientation="Horizontal" Spacing="14">

                            <!--  Date  -->
                            <TextBlock
                                FontSize="12"
                                Foreground="#AAAAAA"
                                Text="{Binding Date}" />

                            <!--  Niveau (couleur dynamique)  -->
                            <TextBlock
                                FontWeight="SemiBold"
                                Foreground="{Binding Level, Converter={StaticResource LogLevelToColorConverter}}"
                                Text="{Binding Level}" />

                        </StackPanel>

                        <!--  Ligne 2 : Message  -->
                        <TextBlock
                            FontSize="13"
                            Text="{Binding Message}"
                            TextWrapping="Wrap" />

                        <!--  Ligne 3 : Contexte  -->
                        <TextBlock
                            FontSize="11"
                            Foreground="#888888"
                            Text="{Binding Context}"
                            TextWrapping="Wrap" />

                    </StackPanel>
                </Border>
            </DataTemplate>

        </Grid.Resources>

        <!--  =========================  -->
        <!--  STRUCTURE PRINCIPALE  -->
        <!--  =========================  -->

        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*" />
            <ColumnDefinition Width="3*" />
            <ColumnDefinition Width="4*" />
        </Grid.ColumnDefinitions>

        <!--  ======================================================  -->
        <!--  ZONE GAUCHE : ARBORESCENCE PROJET (COEUR APP)  -->
        <!--  ======================================================  -->

        <Border
            Grid.Column="0"
            Margin="5"
            Background="#1E1E1E">

            <Grid>

                <!--  STRUCTURE GAUCHE  -->
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <!--  barre du haut  -->
                    <RowDefinition Height="Auto" />
                    <!--  recherche  -->
                    <RowDefinition Height="*" />
                    <!--  tree  -->
                </Grid.RowDefinitions>

                <!--  CHARGEUR DE DOSSIER + BARRE RECHERCHE  -->
                <Grid Grid.Row="0" Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <!--  📂  -->
                        <ColumnDefinition Width="Auto" />
                        <!--  ☑  -->
                        <ColumnDefinition Width="*" />
                        <!--  espace  -->
                        <ColumnDefinition Width="Auto" />
                        <!--  🔍  -->
                    </Grid.ColumnDefinitions>
                    <!--  📂  -->
                    <Button
                        Width="40"
                        Height="40"
                        Click="OnPickFolderClicked"
                        Content="📂"
                        ToolTipService.ToolTip="Ouvrir un dossier" />

                    <!--  ☑ Sélection globale  -->
                    <CheckBox
                        Grid.Column="1"
                        Margin="10,0,0,0"
                        VerticalAlignment="Center"
                        Content="Tout sélectionner"
                        IsChecked="{Binding IsAllSelected, Mode=TwoWay}"
                        Opacity="0.6"
                        ToolTipService.ToolTip="Désactivé temporairement pour performance" />

                    <!--  🔍  -->
                    <Button
                        Grid.Column="3"
                        Width="40"
                        Height="40"
                        Click="OnSearchClicked"
                        Content="🔍"
                        ToolTipService.ToolTip="Rechercher un fichier" />
                </Grid>

                <!--  BARRE DE RECHERCHE  -->
                <TextBox
                    Grid.Row="1"
                    MinHeight="40"
                    Margin="10,0,10,5"
                    PlaceholderText="Rechercher un fichier..."
                    Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    Visibility="{Binding IsSearchVisible, Converter={StaticResource BooleanToVisibilityConverter}}" />

                <!--  ARBORESCENCE  -->
                <Grid Grid.Row="2">

                    <!--  🌳 ARBRE  -->
                    <TreeView ItemsSource="{Binding Tree}" Visibility="{Binding HasSearchResult, Converter={StaticResource BooleanToVisibilityConverter}}">

                        <TreeView.ItemTemplate>
                            <DataTemplate x:DataType="models:FileNode">

                                <TreeViewItem ItemsSource="{Binding Children}" Visibility="{Binding IsVisible, Converter={StaticResource BooleanToVisibilityConverter}}">

                                    <StackPanel Orientation="Horizontal" Spacing="6">

                                        <TextBlock Foreground="White" Text="{Binding ., Converter={StaticResource BoolToIconConverter}}" />

                                        <CheckBox
                                            Content="{Binding Name}"
                                            Foreground="White"
                                            IsChecked="{Binding IsSelected, Mode=TwoWay}" />

                                    </StackPanel>

                                </TreeViewItem>

                            </DataTemplate>
                        </TreeView.ItemTemplate>

                    </TreeView>

                    <!--  🚫 AUCUN RÉSULTAT  -->
                    <TextBlock
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontSize="16"
                        Opacity="0.6"
                        Text="Aucun résultat"
                        Visibility="{Binding HasSearchResult, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />

                </Grid>

            </Grid>

        </Border>

        <!--  ======================================================  -->
        <!--  ZONE CENTRE : OPTIONS UTILISATEUR  -->
        <!--  ======================================================  -->

        <Border
            Grid.Column="1"
            Margin="5"
            Background="#2D2D30">

            <StackPanel
                Width="220"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="22">

                <!--  MODE DÉVELOPPEUR  -->
                <StackPanel HorizontalAlignment="Center" Spacing="6">

                    <TextBlock
                        HorizontalAlignment="Center"
                        FontWeight="SemiBold"
                        Foreground="Orange"
                        Text="🧑🏻‍💻 Mode développeur activé"
                        Visibility="{Binding IsDeveloperMode, Converter={StaticResource BooleanToVisibilityConverter}}" />

                </StackPanel>

                <!--  TITRE  -->
                <TextBlock
                    Margin="0,0,0,20"
                    HorizontalAlignment="Center"
                    FontSize="20"
                    Foreground="White"
                    Text="Choix du format"
                    TextAlignment="Center" />

                <!--  FORMATS  -->
                <StackPanel
                    Margin="0,0,0,25"
                    HorizontalAlignment="Center"
                    Spacing="14">

                    <!--  TXT  -->
                    <RadioButton
                        HorizontalAlignment="Center"
                        Checked="OnTxtSelected"
                        Content="📄 Texte (.txt)"
                        GroupName="Format" />

                    <!--  MD  -->
                    <RadioButton
                        HorizontalAlignment="Center"
                        Checked="OnMdSelected"
                        Content="📝 Markdown (.md)"
                        GroupName="Format" />

                </StackPanel>

                <!--  COPIER  -->
                <Button
                    Width="180"
                    Height="44"
                    Margin="0,10,0,20"
                    Padding="12,0"
                    HorizontalAlignment="Center"
                    Click="OnCopyClicked"
                    Content="📋 Copier le contenu"
                    IsEnabled="{Binding CanCopy}"
                    ToolTipService.ToolTip="Copier le contenu" />

                <!--  AUTRES  -->
                <StackPanel HorizontalAlignment="Center" Spacing="14">

                    <Button
                        Width="180"
                        Height="44"
                        Padding="12,0"
                        Click="OnOptionsClicked"
                        Content="⚙ Paramètres"
                        ToolTipService.ToolTip="Paramètres" />

                    <Button
                        Width="180"
                        Height="44"
                        Padding="12,0"
                        Click="OnStatsClicked"
                        Content="📊 Statistiques"
                        ToolTipService.ToolTip="Statistiques" />

                    <Button
                        Width="180"
                        Height="44"
                        Padding="12,0"
                        Click="OnHelpClicked"
                        Content="❓ Aide"
                        ToolTipService.ToolTip="Aide" />

                    <Button
                        Width="180"
                        Height="44"
                        Padding="12,0"
                        Click="OnAboutClicked"
                        Content="ℹ À propos"
                        ToolTipService.ToolTip="À propos" />


                    <Button
                        Width="180"
                        Height="44"
                        Padding="12,0"
                        Click="OnQuitClicked"
                        Content="🚪 Quitter"
                        ToolTipService.ToolTip="Quitter" />

                </StackPanel>

            </StackPanel>

        </Border>

        <!--  ======================================================  -->
        <!--  ZONE DROITE : APERÇU  -->
        <!--  ======================================================  -->

        <Border
            Grid.Column="2"
            Margin="5"
            Background="#252526">

            <Grid>

                <!--  STRUCTURE EN 2 LIGNES  -->
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!--  ======================================================  -->
                <!--  FEEDBACK  -->
                <!--  ======================================================  -->

                <Border
                    Grid.Row="0"
                    Margin="10,10,10,0"
                    Padding="10,6"
                    HorizontalAlignment="Right"
                    Background="#3A3A3A"
                    CornerRadius="6"
                    Visibility="{Binding IsFeedbackVisible, Converter={StaticResource BooleanToVisibilityConverter}}">

                    <TextBlock
                        MaxWidth="240"
                        FontSize="13"
                        FontWeight="SemiBold"
                        Foreground="White"
                        Text="{Binding FeedbackMessage}"
                        TextWrapping="Wrap" />

                </Border>

                <!--  ======================================================  -->
                <!--  CONTENU + OVERLAY  -->
                <!--  ======================================================  -->

                <Grid Grid.Row="1">

                    <!--  CONTENU  -->
                    <Grid>

                        <ScrollViewer
                            HorizontalScrollBarVisibility="Auto"
                            VerticalScrollBarVisibility="Auto"
                            Visibility="{Binding IsPreviewEmpty, Converter={StaticResource InverseBooleanToVisibilityConverter}}">

                            <TextBlock
                                Margin="20"
                                FontFamily="Cascadia Code"
                                FontSize="13"
                                Foreground="White"
                                Text="{Binding PreviewText}"
                                TextWrapping="NoWrap" />
                        </ScrollViewer>

                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontSize="16"
                            Foreground="White"
                            Text="Aucun fichier sélectionné..."
                            Visibility="{Binding IsPreviewEmpty, Converter={StaticResource BooleanToVisibilityConverter}}" />

                    </Grid>

                    <!--  LOADER OVERLAY  -->
                    <Grid Background="#80000000" Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">

                        <StackPanel
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="10">

                            <ProgressRing
                                Width="50"
                                Height="50"
                                IsActive="True" />

                            <TextBlock
                                HorizontalAlignment="Center"
                                Foreground="White"
                                Text="Chargement..." />
                        </StackPanel>

                    </Grid>

                    <!--  ERREUR OVERLAY  -->
                    <Grid Background="#CC000000" Visibility="{Binding HasError, Converter={StaticResource BooleanToVisibilityConverter}}">

                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Foreground="Red"
                            Text="{Binding ErrorMessage}" />

                    </Grid>

                </Grid>

                <!--  ======================================================  -->
                <!--  ZONE BASSE : EXPORT  -->
                <!--  ======================================================  -->

                <Border
                    Grid.Row="2"
                    Padding="10"
                    Background="#333333">

                    <Grid>

                        <!--  🧱 NOUVELLE STRUCTURE  -->
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <!--  Gauche  -->
                            <ColumnDefinition Width="*" />
                            <!--  Espace  -->
                            <ColumnDefinition Width="Auto" />
                            <!--  Droite  -->
                        </Grid.ColumnDefinitions>

                        <!--  =========================  -->
                        <!--  GAUCHE : SIMULATION + LOGS  -->
                        <!--  =========================  -->
                        <StackPanel
                            Grid.Column="0"
                            VerticalAlignment="Center"
                            Orientation="Horizontal"
                            Spacing="10">

                            <!--  🧪 SIMULATION  -->
                            <Button
                                Height="40"
                                Padding="12,0"
                                Click="OnSimulationClicked"
                                Content="{Binding SimulationLabel}"
                                ToolTipService.ToolTip="Simulation"
                                Visibility="{Binding IsSimulationVisible, Converter={StaticResource BooleanToVisibilityConverter}}" />

                            <!--  🧾 LOGS  -->
                            <Grid>

                                <Button
                                    Height="40"
                                    Padding="12,0"
                                    Click="OnLogsClicked"
                                    Content="🧾 Logs"
                                    ToolTipService.ToolTip="Afficher les logs" />

                                <!--  🔴 BADGE  -->
                                <Border
                                    Height="18"
                                    MinWidth="18"
                                    Margin="0,-4,-4,0"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Top"
                                    Background="Red"
                                    CornerRadius="9"
                                    Visibility="{Binding HasLogErrors, Converter={StaticResource BooleanToVisibilityConverter}}">

                                    <TextBlock
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontSize="11"
                                        Foreground="White"
                                        Text="{Binding LogErrorCount}" />
                                </Border>

                            </Grid>

                        </StackPanel>

                        <!--  =========================  -->
                        <!--  DROITE : EXPORT  -->
                        <!--  =========================  -->
                        <Button
                            Grid.Column="2"
                            Height="40"
                            MinWidth="140"
                            Margin="10,0,10,0"
                            HorizontalAlignment="Right"
                            Click="OnExportClicked"
                            Content="📤 Exporter le fichier"
                            IsEnabled="{Binding CanExport}"
                            ToolTipService.ToolTip="Exporter le fichier" />

                    </Grid>

                </Border>

            </Grid>

        </Border>
    </Grid>
</Window>
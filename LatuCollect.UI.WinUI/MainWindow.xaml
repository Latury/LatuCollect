<!--
    ╔══════════════════════════════════════════════════════════════════════╗
    ║                        LATUCOLLECT                                   ║
    ║  Module : UI                                                         ║
    ║  Fichier : MainWindow.xaml                                           ║
    ║                                                                      ║
    ║  Rôle : Interface utilisateur principale                             ║
    ║                                                                      ║
    ║  Respect ALC :                                                       ║
    ║  - Aucune logique métier                                             ║
    ║  - Binding uniquement                                                ║
    ║  - Structure claire et maintenable                                   ║
    ╚══════════════════════════════════════════════════════════════════════╝
-->

<Window
    x:Class="LatuCollect.UI.WinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="using:LatuCollect.UI.WinUI.Converters"
    xmlns:models="using:LatuCollect.UI.WinUI.Models">

    <Grid>

        <!--  =========================  -->
        <!--  RESSOURCES UI  -->
        <!--  =========================  -->

        <Grid.Resources>
            <conv:BoolToIconConverter x:Key="BoolToIconConverter" />
            <conv:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        </Grid.Resources>

        <!--  =========================  -->
        <!--  STRUCTURE PRINCIPALE  -->
        <!--  =========================  -->

        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*" />
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="5*" />
        </Grid.ColumnDefinitions>

        <!--  ======================================================  -->
        <!--  ZONE GAUCHE : ARBORESCENCE PROJET (COEUR APP)  -->
        <!--  ======================================================  -->

        <Border
            Grid.Column="0"
            Margin="5"
            Background="#1E1E1E">

            <Grid>

                <!--  STRUCTURE GAUCHE  -->
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!--  CHARGEUR DE DOSSIER + BARRE RECHERCHE  -->
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!--  Chargement dossier  -->
                    <Button
                        Width="40"
                        Height="40"
                        Click="OnPickFolderClicked"
                        Content="📂" />

                    <!--  Barre de recherche  -->
                    <TextBox
                        Grid.Column="1"
                        MinHeight="40"
                        Margin="10,0,0,0"
                        PlaceholderText="Rechercher un fichier..."
                        Text="{Binding SearchText, Mode=TwoWay}" />
                </Grid>

                <!--  ARBORESCENCE  -->
                <TreeView Grid.Row="1" ItemsSource="{Binding Tree}">

                    <TreeView.ItemTemplate>
                        <DataTemplate x:DataType="models:FileNode">

                            <!--  🔥 IMPORTANT : TreeViewItem ici  -->
                            <TreeViewItem ItemsSource="{Binding Children}">

                                <StackPanel Orientation="Horizontal" Spacing="6">

                                    <!--  Icône  -->
                                    <TextBlock Foreground="White" Text="{Binding ., Converter={StaticResource BoolToIconConverter}}" />

                                    <!--  Checkbox  -->
                                    <CheckBox
                                        Content="{Binding Name}"
                                        Foreground="White"
                                        IsChecked="{Binding IsSelected, Mode=TwoWay}" />

                                </StackPanel>

                            </TreeViewItem>

                        </DataTemplate>
                    </TreeView.ItemTemplate>

                </TreeView>

            </Grid>

        </Border>

        <!--  ======================================================  -->
        <!--  ZONE CENTRE : OPTIONS UTILISATEUR  -->
        <!--  ======================================================  -->

        <!--  ======================================================  -->
        <!--  ZONE CENTRE : OPTIONS UTILISATEUR  -->
        <!--  ======================================================  -->

        <Border
            Grid.Column="1"
            Margin="5"
            Background="#2D2D30">

            <StackPanel
                Width="180"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="12">

                <!--  TITRE  -->
                <TextBlock
                    Margin="0,0,0,20"
                    HorizontalAlignment="Center"
                    FontSize="20"
                    Foreground="White"
                    Text="Choix du format"
                    TextAlignment="Center" />

                <!--  FORMATS  -->
                <StackPanel
                    Margin="0,0,0,25"
                    HorizontalAlignment="Center"
                    Spacing="10">

                    <!--  TXT  -->
                    <RadioButton
                        HorizontalAlignment="Center"
                        Checked="OnTxtSelected"
                        Content=".txt"
                        GroupName="Format" />

                    <!--  MD  -->
                    <RadioButton
                        HorizontalAlignment="Center"
                        Checked="OnMdSelected"
                        Content=".md"
                        GroupName="Format" />

                </StackPanel>

                <!--  COPIER  -->
                <Button
                    Width="120"
                    Height="40"
                    Margin="0,0,0,25"
                    HorizontalAlignment="Center"
                    Click="OnCopyClicked"
                    Content="Copier"
                    IsEnabled="{Binding CanCopy}" />

                <!--  AUTRES  -->
                <StackPanel HorizontalAlignment="Center" Spacing="12">

                    <Button
                        Width="120"
                        Height="36"
                        Click="OnOptionsClicked"
                        Content="Options" />

                    <Button
                        Width="120"
                        Height="36"
                        Click="OnHelpClicked"
                        Content="Aide" />

                    <Button
                        Width="120"
                        Height="36"
                        Click="OnAboutClicked"
                        Content="À propos" />

                    <Button
                        Width="120"
                        Height="36"
                        Click="OnQuitClicked"
                        Content="Quitter" />

                </StackPanel>

            </StackPanel>

        </Border>

        <!--  ======================================================  -->
        <!--  ZONE DROITE : APERÇU  -->
        <!--  ======================================================  -->

        <Border
            Grid.Column="2"
            Margin="5"
            Background="#252526">

            <Grid>

                <!--  =========================  -->
                <!--  CONTENU FICHIER  -->
                <!--  Visible SI contenu existe  -->
                <!--  =========================  -->

                <ScrollViewer
                    HorizontalScrollBarVisibility="Auto"
                    VerticalScrollBarVisibility="Auto"
                    Visibility="{Binding IsPreviewEmpty, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Invert}">

                    <TextBlock
                        Margin="20"
                        FontFamily="Cascadia Code"
                        FontSize="13"
                        Foreground="White"
                        Text="{Binding PreviewText}"
                        TextAlignment="Left"
                        TextWrapping="NoWrap" />
                </ScrollViewer>

                <!--  =========================  -->
                <!--  MESSAGE VIDE  -->
                <!--  Visible SI aucun fichier  -->
                <!--  =========================  -->

                <TextBlock
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontSize="16"
                    Foreground="White"
                    Text="Aucun fichier sélectionné..."
                    Visibility="{Binding IsPreviewEmpty, Converter={StaticResource BooleanToVisibilityConverter}}" />

            </Grid>

        </Border>

        <!--  ======================================================  -->
        <!--  ZONE BASSE : EXPORT  -->
        <!--  ======================================================  -->

        <Border
            Grid.Row="1"
            Grid.ColumnSpan="3"
            Padding="10"
            Background="#333333">

            <Grid>

                <Grid>

                    <!--  2 colonnes  -->
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!--  🧪 BOUTON SIMULATION  -->
                    <Button
                        Grid.Column="0"
                        Height="40"
                        Padding="12,0"
                        HorizontalAlignment="Left"
                        Click="OnSimulationClicked"
                        Content="{Binding SimulationLabel}" />

                    <!--  📤 EXPORT  -->
                    <Button
                        Grid.Column="1"
                        Width="140"
                        Height="40"
                        HorizontalAlignment="Right"
                        Click="OnExportClicked"
                        Content="Exporter"
                        IsEnabled="{Binding CanExport}" />

                </Grid>
            </Grid>
        </Border>

    </Grid>
</Window>
<!--  =========================  -->
<!--  🧱 ROOT WINDOW  -->
<!--  =========================  -->

<Window
    x:Class="LatuCollect.UI.WinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="using:LatuCollect.UI.WinUI.Converters"
    xmlns:models="using:LatuCollect.UI.WinUI.Models">

    <!--  =========================  -->
    <!--  🧱 ROOT GRID  -->
    <!--  =========================  -->
    <Grid>

        <!--  ======================================================  -->
        <!--  🧱 MAIN CONTENT  -->
        <!--  ======================================================  -->
        <Grid x:Name="MainContent">

            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="4*" />
            </Grid.ColumnDefinitions>

            <!--  ======================================================  -->
            <!--  📁 ZONE GAUCHE  -->
            <!--  ======================================================  -->
            <Border
                Grid.Column="0"
                Margin="5"
                Background="#1E1E1E">

                <Grid>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!--  HEADER  -->
                    <Grid Grid.Row="0" Margin="10">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Button
                            Width="40"
                            Height="40"
                            Click="OnPickFolderClicked"
                            Content="📂" />
                        <Button
                            Grid.Column="3"
                            Width="40"
                            Height="40"
                            Click="OnSearchClicked"
                            Content="🔍" />

                    </Grid>

                    <!--  SEARCH  -->
                    <TextBox
                        Grid.Row="1"
                        MinHeight="40"
                        Margin="10,0,10,5"
                        PlaceholderText="Rechercher un fichier..."
                        Text="{Binding SearchText, Mode=TwoWay}"
                        Visibility="{Binding IsSearchVisible, Converter={StaticResource BooleanToVisibilityConverter}}" />

                    <!--  TREE  -->
                    <Grid Grid.Row="2">

                        <TreeView ItemsSource="{Binding FilteredTree}" Visibility="{Binding IsTreeEmpty, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />

                        <Grid IsHitTestVisible="False">
                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Text="Veuillez sélectionner un dossier"
                                Visibility="{Binding IsTreeEmpty, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        </Grid>

                    </Grid>

                    <Border
                        Grid.Row="3"
                        Height="60"
                        Opacity="0" />

                </Grid>
            </Border>

            <!--  ======================================================  -->
            <!--  ⚙️ ZONE CENTRE  -->
            <!--  ======================================================  -->
            <Border
                Grid.Column="1"
                Margin="5"
                Background="#2D2D30">

                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">

                    <TextBlock Text="Choix du format" />

                    <RadioButton Content="TXT" IsChecked="{Binding SelectedFormat, Converter={StaticResource StringEqualsConverter}, ConverterParameter=.txt}" />

                    <RadioButton Content="MD" IsChecked="{Binding SelectedFormat, Converter={StaticResource StringEqualsConverter}, ConverterParameter=.md}" />

                </StackPanel>

            </Border>

            <!--  ======================================================  -->
            <!--  👁️ ZONE DROITE  -->
            <!--  ======================================================  -->
            <Border
                Grid.Column="2"
                Margin="5"
                Background="#252526">

                <Grid>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!--  FEEDBACK  -->
                    <Border Grid.Row="0" />

                    <!--  CONTENU  -->
                    <Grid Grid.Row="1">

                        <ScrollViewer>
                            <TextBox Text="{Binding PreviewText}" />
                        </ScrollViewer>

                        <Grid Visibility="{Binding IsEmpty}">
                            <TextBlock Text="Aucun fichier sélectionné..." />
                        </Grid>

                        <!--  LOADER  -->
                        <Grid Visibility="{Binding IsLoading}" />

                        <!--  ERROR  -->
                        <Grid Visibility="{Binding HasError}" />

                    </Grid>

                </Grid>

            </Border>

        </Grid>
        <!--  FIN MainContent  -->

        <!--  ======================================================  -->
        <!--  ⚙️ OVERLAY PARAMÈTRES  -->
        <!--  ======================================================  -->
        <Grid
            x:Name="SettingsOverlay"
            Background="#AA000000"
            Canvas.ZIndex="999"
            Visibility="Collapsed">

            <Border
                Width="900"
                Height="600"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="#1E1E1E"
                CornerRadius="8">

                <Grid x:Name="SettingsContainer" />

            </Border>

        </Grid>

    </Grid>
    <!--  FIN ROOT  -->

</Window>   
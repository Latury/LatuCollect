<!--
    ╔══════════════════════════════════════════════════════════════════════╗
    ║                        LATUCOLLECT                                   ║
    ║  Module : UI                                                         ║
    ║  Fichier : MainWindow.xaml                                           ║
    ║                                                                      ║
    ║  Rôle : Interface utilisateur principale                             ║
    ║                                                                      ║
    ║  Respect ALC :                                                       ║
    ║  - Aucune logique métier                                             ║
    ║  - Binding uniquement                                                ║
    ║  - Structure claire et maintenable                                   ║
    ╚══════════════════════════════════════════════════════════════════════╝
-->

<Window
    x:Class="LatuCollect.UI.WinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="using:LatuCollect.UI.WinUI.Converters"
    xmlns:models="using:LatuCollect.UI.WinUI.Models">

    <Grid>

        <!--  =========================  -->
        <!--  RESSOURCES UI  -->
        <!--  =========================  -->

        <Grid.Resources>
            <conv:BoolToIconConverter x:Key="BoolToIconConverter" />
            <conv:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        </Grid.Resources>

        <!--  =========================  -->
        <!--  STRUCTURE PRINCIPALE  -->
        <!--  =========================  -->

        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*" />
            <ColumnDefinition Width="3*" />
            <ColumnDefinition Width="4*" />
        </Grid.ColumnDefinitions>

        <!--  ======================================================  -->
        <!--  ZONE GAUCHE : ARBORESCENCE PROJET (COEUR APP)  -->
        <!--  ======================================================  -->

        <Border
            Grid.Column="0"
            Margin="5"
            Background="#1E1E1E">

            <Grid>

                <!--  STRUCTURE GAUCHE  -->
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <!--  barre du haut  -->
                    <RowDefinition Height="Auto" />
                    <!--  recherche  -->
                    <RowDefinition Height="*" />
                    <!--  tree  -->
                </Grid.RowDefinitions>

                <!--  CHARGEUR DE DOSSIER + BARRE RECHERCHE  -->
                <Grid Grid.Row="0" Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <!--  📂  -->
                        <ColumnDefinition Width="Auto" />
                        <!--  ☑  -->
                        <ColumnDefinition Width="*" />
                        <!--  espace  -->
                        <ColumnDefinition Width="Auto" />
                        <!--  🔍  -->
                    </Grid.ColumnDefinitions>
                    <!--  📂  -->
                    <Button
                        Width="40"
                        Height="40"
                        Click="OnPickFolderClicked"
                        Content="📂" />

                    <!--  ☑  -->
                    <CheckBox
                        Grid.Column="1"
                        Margin="10,0,0,0"
                        VerticalAlignment="Center"
                        Content="Tout sélectionner"
                        IsChecked="{Binding IsAllSelected, Mode=TwoWay}" />

                    <!--  🔍  -->
                    <Button
                        Grid.Column="3"
                        Width="40"
                        Height="40"
                        Click="OnSearchClicked"
                        Content="🔍" />
                </Grid>

                <!--  BARRE DE RECHERCHE  -->
                <TextBox
                    Grid.Row="1"
                    MinHeight="40"
                    Margin="10,0,10,5"
                    PlaceholderText="Rechercher un fichier..."
                    Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                    Visibility="{Binding IsSearchVisible, Converter={StaticResource BooleanToVisibilityConverter}}" />

                <!--  ARBORESCENCE  -->
                <TreeView Grid.Row="2" ItemsSource="{Binding Tree}">

                    <TreeView.ItemTemplate>
                        <DataTemplate x:DataType="models:FileNode">

                            <!--  🔥 IMPORTANT : TreeViewItem ici  -->
                            <TreeViewItem ItemsSource="{Binding Children}" Visibility="{Binding IsVisible, Converter={StaticResource BooleanToVisibilityConverter}}">

                                <StackPanel Orientation="Horizontal" Spacing="6">

                                    <!--  Icône  -->
                                    <TextBlock Foreground="White" Text="{Binding ., Converter={StaticResource BoolToIconConverter}}" />

                                    <!--  Checkbox  -->
                                    <CheckBox
                                        Content="{Binding Name}"
                                        Foreground="White"
                                        IsChecked="{Binding IsSelected, Mode=TwoWay}" />

                                </StackPanel>

                            </TreeViewItem>

                        </DataTemplate>
                    </TreeView.ItemTemplate>

                </TreeView>

            </Grid>

        </Border>

        <!--  ======================================================  -->
        <!--  ZONE CENTRE : OPTIONS UTILISATEUR  -->
        <!--  ======================================================  -->

        <Border
            Grid.Column="1"
            Margin="5"
            Background="#2D2D30">

            <StackPanel
                Width="220"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="22">

                <!--  TITRE  -->
                <TextBlock
                    Margin="0,0,0,20"
                    HorizontalAlignment="Center"
                    FontSize="20"
                    Foreground="White"
                    Text="Choix du format"
                    TextAlignment="Center" />

                <!--  FORMATS  -->
                <StackPanel
                    Margin="0,0,0,25"
                    HorizontalAlignment="Center"
                    Spacing="14">

                    <!--  TXT  -->
                    <RadioButton
                        HorizontalAlignment="Center"
                        Checked="OnTxtSelected"
                        Content="📄 Texte (.txt)"
                        GroupName="Format" />

                    <!--  MD  -->
                    <RadioButton
                        HorizontalAlignment="Center"
                        Checked="OnMdSelected"
                        Content="📝 Markdown (.md)"
                        GroupName="Format" />

                </StackPanel>

                <!--  COPIER  -->
                <Button
                    Width="180"
                    Height="44"
                    Margin="0,10,0,20"
                    Padding="12,0"
                    HorizontalAlignment="Center"
                    Click="OnCopyClicked"
                    Content="📋 Copier le contenu"
                    IsEnabled="{Binding CanCopy}" />

                <!--  AUTRES  -->
                <StackPanel HorizontalAlignment="Center" Spacing="14">

                    <Button
                        Width="180"
                        Height="44"
                        Padding="12,0"
                        Click="OnOptionsClicked"
                        Content="⚙ Paramètres" />

                    <Button
                        Width="180"
                        Height="44"
                        Padding="12,0"
                        Click="OnHelpClicked"
                        Content="❓ Aide" />

                    <Button
                        Width="180"
                        Height="44"
                        Padding="12,0"
                        Click="OnAboutClicked"
                        Content="ℹ À propos" />

                    <Button
                        Width="180"
                        Height="44"
                        Padding="12,0"
                        Click="OnQuitClicked"
                        Content="🚪 Quitter" />

                </StackPanel>

            </StackPanel>

        </Border>

        <!--  ======================================================  -->
        <!--  ZONE DROITE : APERÇU  -->
        <!--  ======================================================  -->

        <Border
            Grid.Column="2"
            Margin="5"
            Background="#252526">

            <Grid>

                <!--  🔥 STRUCTURE EN 2 LIGNES  -->
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!--  ======================================================  -->
                <!--  🔥 FEEDBACK (NOUVEAU)  -->
                <!--  ======================================================  -->

                <Border
                    Grid.Row="0"
                    Margin="10,10,10,0"
                    Padding="10,6"
                    HorizontalAlignment="Right"
                    Background="#3A3A3A"
                    CornerRadius="6"
                    Visibility="{Binding IsFeedbackVisible, Converter={StaticResource BooleanToVisibilityConverter}}">

                    <StackPanel Orientation="Horizontal" Spacing="6">

                        <TextBlock
                            FontSize="13"
                            FontWeight="SemiBold"
                            Foreground="White"
                            Text="{Binding FeedbackMessage}" />

                    </StackPanel>

                </Border>

                <!--  ======================================================  -->
                <!--  CONTENU  -->
                <!--  ======================================================  -->

                <Grid Grid.Row="1">

                    <!--  =========================  -->
                    <!--  CONTENU FICHIER  -->
                    <!--  =========================  -->

                    <ScrollViewer
                        HorizontalScrollBarVisibility="Auto"
                        VerticalScrollBarVisibility="Auto"
                        Visibility="{Binding IsPreviewEmpty, Converter={StaticResource BooleanToVisibilityConverter}, ConverterParameter=Invert}">

                        <TextBlock
                            Margin="20"
                            FontFamily="Cascadia Code"
                            FontSize="13"
                            Foreground="White"
                            Text="{Binding PreviewText}"
                            TextAlignment="Left"
                            TextWrapping="NoWrap" />
                    </ScrollViewer>

                    <!--  =========================  -->
                    <!--  MESSAGE VIDE  -->
                    <!--  =========================  -->

                    <TextBlock
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontSize="16"
                        Foreground="White"
                        Text="Aucun fichier sélectionné..."
                        Visibility="{Binding IsPreviewEmpty, Converter={StaticResource BooleanToVisibilityConverter}}" />

                </Grid>

            </Grid>

        </Border>

        <!--  ======================================================  -->
        <!--  ZONE BASSE : EXPORT  -->
        <!--  ======================================================  -->

        <Border
            Grid.Row="1"
            Grid.ColumnSpan="3"
            Padding="10"
            Background="#333333">

            <Grid>

                <Grid>

                    <!--  2 colonnes  -->
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!--  🧪 BOUTON SIMULATION  -->
                    <Button
                        Grid.Column="0"
                        Height="40"
                        Padding="12,0"
                        HorizontalAlignment="Left"
                        Click="OnSimulationClicked"
                        Content="{Binding SimulationLabel}" />

                    <!--  📤 EXPORT  -->
                    <Button
                        Grid.Column="1"
                        Height="40"
                        MinWidth="140"
                        Margin="10,0,10,0"
                        HorizontalAlignment="Right"
                        Click="OnExportClicked"
                        Content="📤 Exporter le fichier"
                        IsEnabled="{Binding CanExport}" />

                </Grid>
            </Grid>
        </Border>

    </Grid>
</Window>
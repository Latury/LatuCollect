<UserControl
    x:Class="LatuCollect.UI.WinUI.Settings.Panels.SettingsPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>

        <!--  ═════════════════════════════════════════════════════════  -->
        <!--  2. PANEL CENTRAL  -->
        <!--  ═════════════════════════════════════════════════════════  -->

        <Border
            MaxWidth="1400"
            MaxHeight="900"
            Margin="20"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            Background="#1E1E1E"
            CornerRadius="10">
            <Grid>

                <!--  STRUCTURE  -->
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="250" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="60" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!--  ═════════════════════════════════════════════════  -->
                <!--  3. HEADER  -->
                <!--  ═════════════════════════════════════════════════  -->

                <Border
                    Grid.ColumnSpan="2"
                    Padding="20,0,20,0"
                    Background="#2D2D30"
                    CornerRadius="10,10,0,0">

                    <Grid>
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="18"
                            FontWeight="SemiBold"
                            Text="⚙ Paramètres" />

                        <Button
                            Width="44"
                            Height="36"
                            Margin="0,0,10,0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Click="OnCloseClicked"
                            Content="❌" />
                    </Grid>
                </Border>

                <!--  ═════════════════════════════════════════════════  -->
                <!--  4. MENU GAUCHE  -->
                <!--  ═════════════════════════════════════════════════  -->

                <Border
                    Grid.Row="1"
                    Padding="10"
                    Background="#252526">

                    <StackPanel Spacing="6">

                        <TextBlock
                            Margin="5,0,0,10"
                            Opacity="0.7"
                            Text="Navigation" />

                        <!--  Général  -->
                        <Button
                            HorizontalAlignment="Stretch"
                            Click="OnGeneralClicked"
                            Content="⚙ Général" />

                        <!--  Export mode  -->
                        <Button
                            HorizontalAlignment="Stretch"
                            Click="OnExportModeClicked"
                            Content="📤 Mode d’export" />

                        <!--  Exclusions  -->
                        <Button
                            HorizontalAlignment="Stretch"
                            Click="OnExclusionsClicked"
                            Content="📁 Dossiers exclus" />

                    </StackPanel>
                </Border>

                <!--  ═════════════════════════════════════════════════  -->
                <!--  5. CONTENU  -->
                <!--  ═════════════════════════════════════════════════  -->

                <Grid Grid.Row="1" Grid.Column="1">

                    <!--  zone scrollable  -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <Grid>
                            <Frame x:Name="ContentFrame" Margin="30" />
                        </Grid>
                    </ScrollViewer>

                </Grid>

            </Grid>
        </Border>
    </Grid>
</UserControl>
<Page
    x:Class="LatuCollect.UI.WinUI.Settings.Pages.SettingsExclusionsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="using:LatuCollect.UI.WinUI.Converters"
    xmlns:models="using:LatuCollect.Core.Configuration.Models">

    <!--  ======================================================  -->
    <!--  1. RESOURCES  -->
    <!--  ======================================================  -->

    <Page.Resources>

        <conv:StringToVisibilityConverter x:Key="StringToVisibilityConverter" />
        <conv:ExclusionItemVisibilityConverter x:Key="ExclusionItemVisibilityConverter" />

    </Page.Resources>

    <!--  ======================================================  -->
    <!--  2. CONTENU  -->
    <!--  ======================================================  -->
    <StackPanel Padding="20" Spacing="12">

        <!--  ======================================================  -->
        <!--  2.1 TITRE  -->
        <!--  ======================================================  -->
        <TextBlock FontSize="22" Text="📁 Dossiers exclus" />

        <!--  ======================================================  -->
        <!--  2.2 LISTE  -->
        <!--  ======================================================  -->
        <ListView
            x:Name="ExclusionsList"
            MinHeight="200"
            MaxHeight="500"
            ItemsSource="{Binding GroupedExclusions}"
            SelectedItem="{Binding SelectedExclusion, Mode=TwoWay}"
            SelectionChanged="ExclusionsList_SelectionChanged"
            SelectionMode="Single">

            <ListView.ItemTemplate>
                <DataTemplate>

                    <StackPanel>

                        <!--  HEADER  -->
                        <Border
                            Margin="0,14,0,8"
                            Padding="10,8"
                            Background="#2A2A2A"
                            CornerRadius="6">

                            <Border.Visibility>
                                <Binding>
                                    <Binding.Converter>
                                        <conv:StringToVisibilityConverter />
                                    </Binding.Converter>
                                </Binding>
                            </Border.Visibility>

                            <TextBlock
                                FontSize="16"
                                FontWeight="SemiBold"
                                Text="{Binding}" />

                        </Border>

                        <!--  ITEM  -->
                        <Border
                            Margin="0,2,0,2"
                            Padding="8,6"
                            CornerRadius="4">

                            <Border.Visibility>
                                <Binding>
                                    <Binding.Converter>
                                        <conv:ExclusionItemVisibilityConverter />
                                    </Binding.Converter>
                                </Binding>
                            </Border.Visibility>

                            <Grid ColumnSpacing="8">

                                <!--  COLONNES FIXES  -->
                                <Grid.ColumnDefinitions>

                                    <!--  CADENAS  -->
                                    <ColumnDefinition Width="24" />

                                    <!--  ICÔNE  -->
                                    <ColumnDefinition Width="24" />

                                    <!--  TEXTE  -->
                                    <ColumnDefinition Width="*" />

                                </Grid.ColumnDefinitions>

                                <!--  CADENAS  -->
                                <TextBlock
                                    Grid.Column="0"
                                    HorizontalAlignment="Center"
                                    FontSize="16"
                                    Text="🔒"
                                    Visibility="{Binding IsProtected, Converter={StaticResource BooleanToVisibilityConverter}}" />

                                <!--  ICÔNE FICHIER / DOSSIER  -->
                                <TextBlock
                                    Grid.Column="1"
                                    HorizontalAlignment="Center"
                                    FontSize="16"
                                    Text="{Binding Converter={StaticResource ExclusionIconConverter}}" />

                                <!--  ZONE TEXTE  -->
                                <StackPanel
                                    Grid.Column="2"
                                    Orientation="Horizontal"
                                    Spacing="6">

                                    <!--  NOM  -->
                                    <TextBlock
                                        Text="{Binding Name}"
                                        TextTrimming="CharacterEllipsis"
                                        TextWrapping="NoWrap">

                                        <ToolTipService.ToolTip>
                                            <ToolTip Content="{Binding Name}" />
                                        </ToolTipService.ToolTip>

                                    </TextBlock>

                                    <!--  PROTÉGÉ  -->
                                    <TextBlock
                                        Foreground="Gray"
                                        Text="(protégé)"
                                        Visibility="{Binding IsProtected, Converter={StaticResource BooleanToVisibilityConverter}}" />

                                </StackPanel>

                            </Grid>

                        </Border>

                    </StackPanel>

                </DataTemplate>
            </ListView.ItemTemplate>

        </ListView>

        <!--  ======================================================  -->
        <!--  2.3 AJOUT  -->
        <!--  ======================================================  -->
        <StackPanel Orientation="Horizontal" Spacing="10">

            <TextBox
                x:Name="InputExclude"
                Width="250"
                PlaceholderText="Ex: node_modules" />

            <Button Click="OnAddClicked" Content="➕ Ajouter" />

        </StackPanel>

        <!--  ======================================================  -->
        <!--  2.4 ACTIONS  -->
        <!--  ======================================================  -->
        <StackPanel Orientation="Horizontal" Spacing="10">

            <Button
                Click="OnRemoveClicked"
                Content="🗑 Supprimer"
                IsEnabled="{Binding CanRemoveExclusion}" />

        </StackPanel>

    </StackPanel>
</Page>
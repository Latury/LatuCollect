<Page
    x:Class="LatuCollect.UI.WinUI.Settings.Pages.SettingsExportPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--  CONTENEUR GLOBAL  -->
    <Grid>

        <!--  CONTENEUR CENTRAL  -->
        <Grid
            MaxWidth="900"
            Padding="20"
            HorizontalAlignment="Center">

            <!--  SCROLL PRINCIPAL  -->
            <ScrollViewer VerticalScrollBarVisibility="Auto">

                <StackPanel Spacing="20">

                    <!--  FORMAT PAR DÉFAUT  -->
                    <Border
                        Padding="20"
                        Background="#2D2D30"
                        CornerRadius="10">

                        <StackPanel Spacing="12">

                            <!--  TITRE  -->
                            <TextBlock
                                FontSize="18"
                                FontWeight="SemiBold"
                                Text="📄 Format par défaut" />

                            <!--  DESCRIPTION  -->
                            <TextBlock Text="Choisissez le format d’export :" />

                            <!--  OPTIONS  -->
                            <StackPanel Orientation="Horizontal" Spacing="30">

                                <RadioButton
                                    Content=".txt"
                                    GroupName="format"
                                    IsChecked="{Binding DefaultFormat, Mode=TwoWay, Converter={StaticResource StringEqualsConverter}, ConverterParameter=.txt}" />

                                <RadioButton
                                    Content=".md"
                                    GroupName="format"
                                    IsChecked="{Binding DefaultFormat, Mode=TwoWay, Converter={StaticResource StringEqualsConverter}, ConverterParameter=.md}" />

                            </StackPanel>

                        </StackPanel>
                    </Border>

                    <!--  MODE D’EXPORT  -->
                    <Border
                        Padding="20"
                        Background="#2D2D30"
                        CornerRadius="10">

                        <StackPanel Spacing="12">

                            <!--  TITRE  -->
                            <TextBlock
                                FontSize="18"
                                FontWeight="SemiBold"
                                Text="📤 Mode d’export" />

                            <!--  DESCRIPTION  -->
                            <TextBlock Text="Choisissez le mode d’export :" />

                            <!--  OPTIONS  -->
                            <StackPanel Spacing="10">

                                <!--  MODE NORMAL  -->
                                <RadioButton
                                    Content="Normal (complet)"
                                    GroupName="exportMode"
                                    IsChecked="{Binding ExportMode, Mode=TwoWay, Converter={StaticResource StringEqualsConverter}, ConverterParameter=normal}" />

                                <TextBlock Opacity="0.6" Text="Export complet sans limitation" />

                                <!--  MODE IA  -->
                                <RadioButton
                                    Content="IA (limité à 20 000 caractères)"
                                    GroupName="exportMode"
                                    IsChecked="{Binding ExportMode, Mode=TwoWay, Converter={StaticResource StringEqualsConverter}, ConverterParameter=ai}" />

                                <TextBlock Opacity="0.6" Text="Optimisé pour ChatGPT et autres IA" />

                            </StackPanel>

                        </StackPanel>
                    </Border>

                </StackPanel>

            </ScrollViewer>
        </Grid>

    </Grid>
</Page>
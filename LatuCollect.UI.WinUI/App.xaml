<?xml version="1.0" encoding="utf-8" ?>

<!--
    ╔══════════════════════════════════════════════════════════════════════╗
    ║                        LATUCOLLECT                                   ║
    ║  Module : UI.WinUI                                                   ║
    ║  Fichier : App.xaml                                                  ║
    ║                                                                      ║
    ║  Rôle :                                                              ║
    ║  Point d’entrée global des ressources UI                             ║
    ║                                                                      ║
    ║  Responsabilités principales :                                       ║
    ║  - Déclarer les ressources globales (Converters, Styles, etc.)       ║
    ║  - Centraliser les dépendances UI partagées                          ║
    ║                                                                      ║
    ║  IMPORTANT (ALC) :                                                   ║
    ║  ✔ Aucune logique métier                                             ║
    ║  ✔ Accessible par toute l’application                                ║
    ║  ✔ Tous les Converters DOIVENT être définis ici                      ║
    ║                                                                      ║
    ║  Objectif :                                                          ║
    ║  - Éviter duplication des ressources                                 ║
    ║  - Assurer la stabilité XAML (pas de crash runtime)                  ║
    ║                                                                      ║
    ╚══════════════════════════════════════════════════════════════════════╝
-->

<Application
    x:Class="LatuCollect.UI.WinUI.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    xmlns:conv="using:LatuCollect.UI.WinUI.Converters">

    <!--  Namespace des converters  -->
    <Application.Resources>
        <ResourceDictionary>

            <!--  ==============================  -->
            <!--  📦 MERGED DICTIONARIES (WINUI)  -->
            <!--  ==============================  -->
            <ResourceDictionary.MergedDictionaries>

                <!--  Styles WinUI natifs  -->
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />

            </ResourceDictionary.MergedDictionaries>

            <!--  ==============================  -->
            <!--  🔄 CONVERTERS (GLOBAL)  -->
            <!--  ==============================  -->

            <!--  Bool → Visibility  -->
            <conv:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

            <!--  Bool → Visibility inversé  -->
            <conv:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter" />

            <!--  Bool → Icon  -->
            <conv:BoolToIconConverter x:Key="BoolToIconConverter" />

            <!--  LogLevel → Couleur  -->
            <conv:LogLevelToColorConverter x:Key="LogLevelToColorConverter" />

            <!--  Preview visible  -->
            <conv:PreviewVisibleConverter x:Key="PreviewVisibleConverter" />

            <!--  Preview vide  -->
            <conv:PreviewEmptyConverter x:Key="PreviewEmptyConverter" />

            <!--  Comparaison string  -->
            <conv:StringEqualsConverter x:Key="StringEqualsConverter" />

            <!--  Comparaison string insensible à la casse  -->
            <conv:FolderFileIconConverter x:Key="FolderFileIconConverter" />

            <!--  🧾 TEMPLATE LOGS  -->
            <DataTemplate x:Key="LogItemTemplate">
                <Border
                    Margin="2"
                    Padding="6"
                    Background="#2D2D30"
                    BorderBrush="{Binding Level, Converter={StaticResource LogLevelToColorConverter}}"
                    BorderThickness="0,0,0,1"
                    CornerRadius="4">

                    <StackPanel Spacing="4">

                        <!--  Ligne 1 : Date + Niveau  -->
                        <StackPanel Orientation="Horizontal" Spacing="14">

                            <!--  Date  -->
                            <TextBlock
                                FontSize="12"
                                Foreground="#AAAAAA"
                                Text="{Binding Date}" />

                            <!--  Niveau (couleur dynamique)  -->
                            <TextBlock
                                FontWeight="SemiBold"
                                Foreground="{Binding Level, Converter={StaticResource LogLevelToColorConverter}}"
                                Text="{Binding Level}" />

                        </StackPanel>

                        <!--  Ligne 2 : Message  -->
                        <TextBlock
                            FontSize="13"
                            Text="{Binding Message}"
                            TextWrapping="Wrap" />

                        <!--  Ligne 3 : Contexte  -->
                        <TextBlock
                            FontSize="11"
                            Foreground="#888888"
                            Text="{Binding Context}"
                            TextWrapping="Wrap" />

                    </StackPanel>
                </Border>
            </DataTemplate>

        </ResourceDictionary>
    </Application.Resources>
</Application>
<ContentDialog
    x:Class="LatuCollect.UI.WinUI.Dialogs.ConfirmResetDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Réinitialisation"
    CloseButtonText="Annuler"
    DefaultButton="Close"
    PrimaryButtonText="Oui">

    <!--  ═════════════════════════════════════════════════════  -->
    <!--  CONTENU  -->
    <!--  ═════════════════════════════════════════════════════  -->

    <StackPanel Spacing="12">

        <!--  📝 MESSAGE PRINCIPAL  -->
        <TextBlock Text="Voulez-vous vraiment réinitialiser la configuration ?" TextWrapping="Wrap" />

        <!--  ⚠️ AVERTISSEMENT  -->
        <TextBlock
            FontWeight="SemiBold"
            Foreground="Orange"
            Text="⚠ Toutes les préférences seront perdues"
            TextWrapping="Wrap" />

    </StackPanel>

</ContentDialog>
<ContentDialog
    x:Class="LatuCollect.UI.WinUI.Dialogs.OptionsDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="⚙ Paramètres"
    DefaultButton="Primary"
    PrimaryButtonClick="OnPrimaryButtonClick"
    PrimaryButtonText="Fermer">

    <!--  =========================  -->
    <!--  STRUCTURE PRINCIPALE  -->
    <!--  =========================  -->

    <StackPanel Padding="10" Spacing="16">

        <!--  =========================  -->
        <!--  MODE DÉVELOPPEUR  -->
        <!--  =========================  -->
        <StackPanel Spacing="6">

            <!--  TITRE  -->
            <TextBlock
                FontSize="16"
                FontWeight="SemiBold"
                Text="Mode développeur" />

            <!--  TOGGLE  -->
            <ToggleSwitch
                Header="Activer les fonctionnalités avancées"
                IsOn="{Binding IsDeveloperMode, Mode=TwoWay}"
                OffContent="Désactivé"
                OnContent="Activé" />

            <!--  DESCRIPTION  -->
            <TextBlock
                FontSize="12"
                Opacity="0.7"
                Text="Permet d’activer les outils avancés (simulation, logs détaillés, debug)."
                TextWrapping="Wrap" />

        </StackPanel>

        <!--  SÉPARATEUR  -->
        <TextBlock Opacity="0.5" Text="────────────────────────────" />

        <!--  DOSSIERS EXCLUS  -->
        <Button Click="OnExclusionsClicked" Content="📁 Gérer les dossiers exclus" />

        <!--  RESET CONFIG  -->
        <Button
            Background="DarkRed"
            Click="OnResetClicked"
            Content="♻ Réinitialiser la configuration"
            Foreground="White" />

    </StackPanel>

</ContentDialog>